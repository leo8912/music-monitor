# Music Monitor Environment Variables
# Copy this file to .env and adjust as needed

# Database configuration
# For Docker: sqlite+aiosqlite:////config/music_monitor.db
# For Local: sqlite+aiosqlite:///music_monitor.db
DATABASE_URL=sqlite+aiosqlite:////config/music_monitor.db

# Timezone
TZ=Asia/Shanghai

# User and Group ID (for NAS volume permissions)
PUID=1000
PGID=1000

# Server Port
PORT=8000
